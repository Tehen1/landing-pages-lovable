{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "redirects": [
    {
      "source": "/ai-chat",
      "destination": "/ai-poe-chat-verse.html"
    },
    {
      "source": "/fixie",
      "destination": "/fixie-dashboard-navigator-25.html"
    },
    {
      "source": "/seo",
      "destination": "/seo-sea-guru.html"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
