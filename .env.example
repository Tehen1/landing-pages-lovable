# Stripe Configuration
# Remplace par tes vraies clés depuis https://dashboard.stripe.com/apikeys

# Mode TEST (pour développement)
STRIPE_TEST_SECRET_KEY=sk_test_xxxxx
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_xxxxx

# Mode LIVE (pour production - ATTENTION!)
STRIPE_LIVE_SECRET_KEY=sk_live_xxxxx
STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_xxxxx

# Webhook secret (pour recevoir les événements Stripe)
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# URLs de redirection après paiement
SUCCESS_URL=https://ton-domaine.com/success
CANCEL_URL=https://ton-domaine.com/cancel
